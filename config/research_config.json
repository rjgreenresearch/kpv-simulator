        "priority": "high",
        "selectors": {
          "leaderList": ".leader-list, .government-leaders, .state-council-members",
          "name": ".name, .leader-name, .member-name, h3, h4",
          "title": ".title, .position, .post, .rank",
          "department": ".department, .ministry, .organization",
          "biography": ".bio, .description, .profile, .about"
        },
        "additional_urls": [
