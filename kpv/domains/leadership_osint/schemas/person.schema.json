{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "KPV Person Schema",
  "type": "object",
  "required": [
    "id",
    "country_code",
    "name_native",
    "name_latin",
    "aliases",
    "sector",
    "service_or_agency",
    "current_position",
    "career_history",
    "academic_profiles",
    "thematic_keywords",
    "political_alignment_score",
    "technical_expertise_score",
    "doctrinal_influence_score",
    "promotion_velocity_score",
    "purge_or_arrest_risk_score"
  ],
  "properties": {
    "id": {
      "type": ["string", "null"],
      "description": "Unique person identifier assigned by the ingestion pipeline"
    },
    "country_code": {
      "type": "string",
      "pattern": "^[A-Z]{2}$",
      "description": "ISO-style country code (CN, RU, IR, KP)"
    },
    "name_native": {
      "type": ["string", "null"]
    },
    "name_latin": {
      "type": ["string", "null"]
    },
    "aliases": {
      "type": "array",
      "items": { "type": "string" }
    },
    "sector": {
      "type": ["string", "null"],
      "description": "military, nuclear, political, academic, etc."
    },
    "rank_or_grade": {
      "type": ["string", "null"]
    },
    "service_or_agency": {
      "type": ["string", "null"]
    },
    "current_position": {
      "type": ["string", "null"]
    },
    "current_org_id": {
      "type": ["string", "null"]
    },
    "career_history": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "org_id": { "type": ["string", "null"] },
          "position": { "type": ["string", "null"] },
          "start_year": { "type": ["integer", "null"] },
          "end_year": { "type": ["integer", "null"] }
        },
        "required": ["position"]
      }
    },
    "academic_profiles": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "institution": { "type": ["string", "null"] },
          "degree": { "type": ["string", "null"] },
          "year": { "type": ["integer", "null"] }
        }
      }
    },
    "thematic_keywords": {
      "type": "array",
      "items": { "type": "string" }
    },
    "political_alignment_score": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "technical_expertise_score": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "doctrinal_influence_score": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "promotion_velocity_score": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "purge_or_arrest_risk_score": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "notes": {
      "type": ["string", "null"]
    }
  }
}