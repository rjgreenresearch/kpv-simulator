{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "KPV Edge Schema",
  "type": "object",
  "required": [
    "id",
    "source_id",
    "target_id",
    "relationship_type",
    "weight",
    "notes"
  ],
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique edge identifier"
    },
    "source_id": {
      "type": "string",
      "description": "ID of the source node (person or organization)"
    },
    "target_id": {
      "type": "string",
      "description": "ID of the target node (person or organization)"
    },
    "relationship_type": {
      "type": "string",
      "description": "e.g., supervises, reports_to, affiliated_with, commands, collaborates_with"
    },
    "weight": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "Strength of relationship (0–1)"
    },
    "notes": {
      "type": ["string", "null"]
    }
  }
}
