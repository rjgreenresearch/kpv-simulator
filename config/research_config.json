          "title": ".diplomatic-title, .ministerial-position",
          "department": ".bureau, .diplomatic-mission"
        },
        "data_quality": 0.8,
        "update_frequency": "quarterly"
      }
    ],
    "russian_government": [
      {
        "name": "Russian Federation Government",
        "description": "Federal government administration",
        "url": "http://government.ru/en/gov/",
        "language": "ru",
        "type": "government",
        "priority": "high",
        "selectors": {
          "leaderList": ".government-members, .cabinet-members, .federal-ministers",
          "name": ".member-name, .minister-name, h3, h4",
          "title": ".position, .ministerial-post, .government-role",
          "department": ".ministry, .federal-agency, .department",
          "biography": ".biography, .profile, .background"
        },
        "additional_urls": [
          "http://government.ru/en/gov/persons/",
          "http://government.ru/en/ministries/"
        ],
        "data_quality": 0.9,
        "update_frequency": "monthly"
      },
      {
        "name": "Ministry of Defense of Russia",
        "description": "Russian Armed Forces leadership",
        "url": "https://eng.mil.ru/",
        "language": "ru", 
        "type": "military",
        "priority": "high",
        "selectors": {
          "leaderList": ".leadership, .command-structure, .general-staff",
          "name": ".officer-name, .commander-name, .general-name",
          "title": ".military-rank, .command-position, .staff-position",
          "department": ".service-branch, .military-district, .command",
          "biography": ".service-history, .military-background"
        },
        "data_quality": 0.85,
