{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Leadership Edge",
  "type": "object",
  "required": ["source", "target", "type"],
  "properties": {
    "source": { "type": "string" },
    "target": { "type": "string" },
    "type": {
      "type": "string",
      "description": "commands, reports_to, patronage, coauthor, cohort, business_tie, etc."
    },
    "weight": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0
    },
    "evidence": {
      "type": "array",
      "items": { "type": "string" }
    },
    "notes": {
      "type": "string",
      "nullable": true
    }
  },
  "additionalProperties": false
}