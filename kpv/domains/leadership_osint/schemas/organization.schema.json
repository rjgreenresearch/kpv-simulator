{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "KPV Organization Schema",
  "type": "object",
  "required": [
    "id",
    "country_code",
    "name",
    "type",
    "parent_org_id",
    "thematic_keywords",
    "notes"
  ],
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique organization identifier"
    },
    "country_code": {
      "type": "string",
      "pattern": "^[A-Z]{2}$",
      "description": "ISO-style country code (CN, RU, IR, KP)"
    },
    "name": {
      "type": ["string", "null"],
      "description": "Official organization name"
    },
    "type": {
      "type": ["string", "null"],
      "description": "military, political, academic, industrial, intelligence, etc."
    },
    "parent_org_id": {
      "type": ["string", "null"],
      "description": "ID of parent organization, if applicable"
    },
    "thematic_keywords": {
      "type": "array",
      "items": { "type": "string" }
    },
    "notes": {
      "type": ["string", "null"]
    }
  }
}
